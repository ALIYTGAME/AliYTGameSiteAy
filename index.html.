<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>AliYTGame.com | Official</title>
  <style>
    :root {
      --primary-color: #ff8c00; /* Твой любимый оранжевый цвет мандаринов */
      --bg-color: #ffffff;
      --card-bg: #f5f5f5;
      --text-main: #1a1a1a;
      --header-bg: rgba(255, 255, 255, 0.95);
      --border-color: #dddddd;
      --neon-shadow: 0 0 15px rgba(255, 140, 0, 0.5);
    }

    @media (prefers-color-scheme: dark) {
      :root {
        --bg-color: #0f0f0f;
        --card-bg: #1a1a1a;
        --text-main: #ffffff;
        --header-bg: rgba(26, 26, 26, 0.95);
        --border-color: #222222;
      }
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      margin: 0;
      font-family: 'Segoe UI', Roboto, sans-serif;
      background-color: var(--bg-color);
      color: var(--text-main);
      transition: 0.3s;
      text-align: center;
      line-height: 1.6;
    }

    header {
      background: var(--header-bg);
      padding: 15px 5%;
      display: flex;
      justify-content: space-between;
      align-items: center;
      position: sticky;
      top: 0;
      z-index: 100;
      border-bottom: 3px solid var(--primary-color);
      backdrop-filter: blur(10px);
    }

    .logo-section {
      display: flex;
      align-items: center;
      gap: 12px;
      cursor: pointer;
      user-select: none;
    }

    .avatar-placeholder {
      width: 45px;
      height: 45px;
      border-radius: 12px;
      background: var(--primary-color);
      color: white;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: bold;
      border: 2px solid #fff;
      box-shadow: var(--neon-shadow);
      font-size: 18px;
    }

    .burger-menu {
      font-size: 32px;
      cursor: pointer;
      color: var(--primary-color);
    }

    .menu-overlay {
      position: fixed;
      top: 0;
      right: -100%;
      width: 100%;
      height: 100%;
      background: var(--bg-color);
      z-index: 1000;
      transition: 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      display: flex;
      flex-direction: column;
      align-items: center;
      padding-top: 80px;
    }

    .menu-overlay.active {
      right: 0;
    }

    .close-btn {
      position: absolute;
      top: 20px;
      right: 25px;
      font-size: 45px;
      color: #ff5252;
      cursor: pointer;
    }

    .menu-links {
      display: flex;
      flex-direction: column;
      gap: 20px;
    }

    .menu-item {
      text-decoration: none;
      color: var(--text-main);
      font-weight: bold;
      font-size: 22px;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .container {
      max-width: 800px;
      margin: 20px auto;
      padding: 0 20px 50px 20px;
    }

    .section {
      background: var(--card-bg);
      padding: 35px 25px;
      border-radius: 30px;
      margin-bottom: 30px;
      border: 1px solid var(--border-color);
      box-shadow: 0 10px 30px rgba(0,0,0,0.05);
      animation: fadeIn 0.8s ease-out;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .big-avatar {
      width: 130px;
      height: 130px;
      border-radius: 35px;
      background: var(--primary-color);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 55px;
      color: white;
      font-weight: bold;
      box-shadow: var(--neon-shadow);
      margin: 0 auto 25px auto;
    }

    .history-list {
      list-style: none;
      padding: 0;
      text-align: left;
      display: inline-block;
      width: 100%;
      max-width: 500px;
    }

    .history-list li {
      margin-bottom: 15px;
      padding: 15px;
      border-left: 4px solid var(--primary-color);
      background: rgba(255, 140, 0, 0.05);
      border-radius: 0 15px 15px 0;
    }

    textarea {
      width: 100%;
      box-sizing: border-box;
      border-radius: 15px;
      background: var(--bg-color);
      color: var(--text-main);
      border: 2px solid var(--border-color);
      padding: 15px;
      font-size: 16px;
      outline: none;
      transition: 0.3s;
    }

    textarea:focus {
      border-color: var(--primary-color);
    }

    .btn-send {
      margin-top: 20px;
      padding: 15px 45px;
      background: var(--primary-color);
      color: white;
      border: none;
      border-radius: 15px;
      font-weight: bold;
      font-size: 18px;
      cursor: pointer;
      box-shadow: var(--neon-shadow);
      transition: 0.3s;
    }

    .btn-send:active {
      transform: scale(0.95);
    }

    #admin-panel {
      display: none;
      border: 3px dashed #ff5252;
      background: rgba(255, 82, 82, 0.05);
    }

    .footer {
      margin-top: 50px;
      font-size: 14px;
      opacity: 0.6;
      padding-bottom: 30px;
    }
  </style>
</head>
<body>

  <header>
    <div class="logo-section" onclick="activateAdmin()">
      <div class="avatar-placeholder">AY</div>
      <span style="font-weight:bold; color:var(--primary-color); font-size: 20px;">AliYTGame</span>
    </div>
    <div class="burger-menu" onclick="toggleMenu()">☰</div>
  </header>

  <div class="menu-overlay" id="menu">
    <div class="close-btn" onclick="toggleMenu()">×</div>
    <div class="menu-links">
      <a href="#about" class="menu-item" onclick="toggleMenu()">👤 ОБО МНЕ</a>
      <a href="#my-game" class="menu-item" onclick="toggleMenu()">🎮 МОЯ ИГРА</a>
      <a href="#history" class="menu-item" onclick="toggleMenu()">📖 ИСТОРИЯ</a>
      <a href="#idea-form" class="menu-item" onclick="toggleMenu()">💡 ИДЕИ</a>
      <a href="https://www.youtube.com/@AliYTGAME005" class="menu-item" target="_blank">🔴 YOUTUBE</a>
      <a href="https://t.me/AliYTGame005" class="menu-item" target="_blank">✈️ TELEGRAM</a>
      <a href="#admin-panel" class="menu-item" id="secret-tab" style="display: none; color: #ff5252;" onclick="toggleMenu()">🔒 АДМИН ПАНЕЛЬ</a>
    </div>
  </div>

  <div class="container">
    <section class="section" id="about">
      <div class="big-avatar">AY</div>
      <h1>Привет, я Али! 😎</h1>
      <div style="font-size: 18px;">
        <p>Я <strong>AliYTGame</strong> — ютубер из Ташкента и начинающий разработчик.</p>
        <p>Мне 11 лет, я учусь в 5 классе и я настоящий <strong>отличник</strong>.</p>
        <p>Для записи видео я использую крутой микрофон <strong>Jmary MC-PW9</strong>.</p>
        <p>Мои любимые игры: <strong>Brawl Stars</strong>, <strong>Roblox</strong>, <strong>Minecraft</strong> и <strong>FIFA</strong>.</p>
      </div>
    </section>

    <section class="section" id="my-game">
      <h2>🎮 Моя игра</h2>
      <p>Я активно работаю над своей собственной игрой. Следите за новостями на моем канале, чтобы первым узнать о выходе!</p>
    </section>

    <section class="section" id="history">
      <h2>📖 Мой путь к мечте</h2>
      <ul class="history-list">
        <li><strong>2024 год:</strong> Начало пути и покупка микрофона Jmary.</li>
        <li><strong>Лето 2025:</strong> Отдых на даче и крутые планы для канала.</li>
        <li><strong>Апрель 2026:</strong> Запуск этого официального сайта.</li>
        <li><strong>Цель:</strong> 100,000 подписчиков! 🚀</li>
      </ul>
    </section>

    <section class="section" id="idea-form">
      <h2>💡 Предложить идею</h2>
      <p>Твоя идея может попасть в следующее видео или в мою игру!</p>
      <textarea id="idea-input" rows="4" placeholder="Напиши свою крутую идею здесь..."></textarea>
      <button class="btn-send" onclick="sendIdea()">ОТПРАВИТЬ АЛИ</button>
    </section>

    <section class="section" id="admin-panel">
      <h2 style="color:#ff5252;">🔒 Панель администратора</h2>
      <div id="ideas-list" style="text-align: left;">Идей пока нет...</div>
      <button class="btn-send" style="background:#444;" onclick="clearIdeas()">ОЧИСТИТЬ ВСЁ</button>
    </section>

    <div class="footer">
      © 2026 AliYTGame. Создано с душой.
    </div>
  </div>

  <script>
    function toggleMenu() {
      document.getElementById('menu').classList.toggle('active');
    }

    function sendIdea() {
      const input = document.getElementById('idea-input');
      if (input.value.trim() === "") return alert("Пожалуйста, напиши текст идеи!");
      
      let ideas = JSON.parse(localStorage.getItem('ali_ideas') || '[]');
      ideas.push({
        text: input.value,
        date: new Date().toLocaleString()
      });
      localStorage.setItem('ali_ideas', JSON.stringify(ideas));
      
      alert("Круто! Идея сохранена в базе.");
      input.value = "";
      renderIdeas();
    }

    function renderIdeas() {
      const list = document.getElementById('ideas-list');
      let ideas = JSON.parse(localStorage.getItem('ali_ideas') || '[]');
      if (ideas.length === 0) {
        list.innerHTML = "Идей пока нет...";
        return;
      }
      list.innerHTML = ideas.map((id, index) => 
        `<div style="padding:15px; border-bottom:1px solid var(--border-color); margin-bottom:10px;">
          <small style="color:var(--primary-color)">${id.date}</small><br>
          <strong>${index + 1}.</strong> ${id.text}
        </div>`
      ).join('');
    }

    function clearIdeas() {
      if(confirm("Али, ты уверен, что хочешь удалить все идеи?")) {
        localStorage.removeItem('ali_ideas');
        renderIdeas();
      }
    }

    let taps = 0;
    let tapTimer;
    function activateAdmin() {
      taps++;
      clearTimeout(tapTimer);
      tapTimer = setTimeout(() => { taps = 0; }, 2000);
      
      if (taps === 5) {
        let pass = prompt("Секретный код (Али, ты его знаешь!):");
        if (pass === "Ali100k") {
          document.getElementById('admin-panel').style.display = 'block';
          document.getElementById('secret-tab').style.display = 'block';
          renderIdeas();
          alert('✅ Доступ разрешен. Привет, Босс!');
        } else {
          alert('❌ Неверный пароль!');
          taps = 0;
        }
      }
    }
  </script>
</body>
</html>

